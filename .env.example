# ── Ably ──────────────────────────────────────────────────────────────────────
# Real-time pub/sub for host→viewer broadcast.
# Create a free account at ably.com, then copy the Root API key.
# Format: <app-id>.<key-id>:<secret>
ABLY_API_KEY=

# ── Groq ──────────────────────────────────────────────────────────────────────
# Used for two things:
#   1. Whisper v3 Turbo audio transcription  (/api/transcribe)
#   2. LLaMA 3.1-8b translation fallback     (/api/translate)
#
# Supply two keys to double the free-tier rate limit via round-robin.
# A single key also works — set GROQ_API_KEY_1 and leave _2 blank.
GROQ_API_KEY_1=
GROQ_API_KEY_2=

# ── DeepL (optional) ──────────────────────────────────────────────────────────
# Client-side translation fallback. Free tier at deepl.com/pro-api.
# Leave blank to skip DeepL; the app falls back to Google Translate automatically.
# Note: this key is exposed to the browser (VITE_ prefix).
VITE_DEEPL_API_KEY=
